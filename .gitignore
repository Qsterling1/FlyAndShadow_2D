# Unity .gitignore
# Based on https://github.com/github/gitignore/blob/main/Unity.gitignore

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Plastic SCM workspace
.plastic/

# Blender intermediate files
*.blend1
*.blend1.meta

# Memory captures can be large and may contain sensitive data
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio cache
.vs/

# Gradle cache
.gradle/

# Autogenerated solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity-generated meta files for ignored assets
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# TestRunner generated scenes
InitTestScene*.unity*

# Addressables defaults
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting generated files
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated play mode test scenes
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Local notes and working files
/Planning_Documents/
/Docs/
/Assets/_Backup*/
/Assets/_Backup*/**
/Assets/_Documentation/
/Assets/_Documentation.meta
/Assets/_Recovery/
/project-template/
/skills-pack/
/[Ss]ession_*
*_ledger.md
*_audit.md
*session_log*
SHIP_TODO.md
QA.md
GITIGNORE_SUMMARY.md
ignore.conf
.vscode/

# Local screenshots / capture dumps (not for repo)
/Assets/Screenshots/
/Assets/Screenshots.meta

# IDE caches that slip through
*.lscache

# Collectibles sprite library: AI-generated, pending manual curation.
# Block the entire folder, then opt-in only the sprites the scene actually uses.
# As more sprites are curated, add matching `!` entries below.
/Assets/_Art/_Sprites/_UI/Collectibles/*
!/Assets/_Art/_Sprites/_UI/Collectibles/Achievement_Speedster.png
!/Assets/_Art/_Sprites/_UI/Collectibles/Achievement_Speedster.png.meta
!/Assets/_Art/_Sprites/_UI/Collectibles/Badge_New.png
!/Assets/_Art/_Sprites/_UI/Collectibles/Badge_New.png.meta
!/Assets/_Art/_Sprites/_UI/Collectibles/Character_LatrellNewton.png
!/Assets/_Art/_Sprites/_UI/Collectibles/Character_LatrellNewton.png.meta
!/Assets/_Art/_Sprites/_UI/Collectibles/Collectibles_Background.png
!/Assets/_Art/_Sprites/_UI/Collectibles/Collectibles_Background.png.meta
!/Assets/_Art/_Sprites/_UI/Collectibles/DruryStar_001.png
!/Assets/_Art/_Sprites/_UI/Collectibles/DruryStar_001.png.meta
